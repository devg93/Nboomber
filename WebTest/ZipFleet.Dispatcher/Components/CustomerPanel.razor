@*     { *@
@*         try *@
@*         { *@
@*             var activeRide = await Api.GetActiveRideAsync(); *@
@*             if (activeRide != null) *@
@*             { *@
@*                 State.SetCustomerRide(activeRide.Id.ToString(), activeRide.StatusText); *@
@*                 Log($"Recovered active ride: {activeRide.Id.ToString()[..8]}…", "success"); *@
@*                 if (activeRide.StatusText == "Requested") *@
@*                     StartCountdown(); *@
@*             } *@
@*         } *@
@*         catch { } *@
@*     } *@
@* *@
@*     private async Task Logout() *@
@*     { *@
@*         _rideTimer?.Dispose(); *@
@*         _rideTimer = null; *@
@*         if (!string.IsNullOrEmpty(State.CustomerRideId)) *@
@*         { *@
@*             try { await Api.CancelAsync(State.CustomerRideId); } catch { } *@
@*         } *@
@*         await SignalR.DisconnectAsync(); *@
@*         Api.ClearToken(); *@
@*         State.SetCustomerAuth("", "", ""); *@
@*         State.ClearCustomerRide(); *@
@*         _phone = ""; *@
@*         _clickCount = 0; *@
@*         _pickup = null; *@
@*         _destination = null; *@
@*         _ = JS.InvokeVoidAsync("leafletInterop.clearMarkers"); *@
@*     } *@
@* *@
@*     private async Task CreateRide() *@
@*     { *@
@*         if (!_pickup.HasValue || !_destination.HasValue) return; *@
@*         _busy = true; *@
@*         try *@
@*         { *@
@*             var ride = await Api.CreateRideAsync( *@
@*                 (decimal)_pickup.Value.lat, (decimal)_pickup.Value.lng, *@
@*                 (decimal)_destination.Value.lat, (decimal)_destination.Value.lng); *@
@*             State.SetCustomerRide(ride.Id.ToString(), "Requested"); *@
@*             Log($"Ride created! Price: {ride.Price:F2} GEL, Distance: {ride.DistanceKm:F1} km", "success"); *@
@*             StartCountdown(); *@
@*         } *@
@*         catch (Exception ex) *@
@*         { *@
@*             Log($"Create ride failed: {ex.Message}", "error"); *@
@*         } *@
@*         finally { _busy = false; } *@
@*     } *@
@* *@
@*     private async Task CancelRide() *@
@*     { *@
@*         if (string.IsNullOrEmpty(State.CustomerRideId)) return; *@
@*         _rideTimer?.Dispose(); *@
@*         _rideTimer = null; *@
@*         _busy = true; *@
@*         try *@
@*         { *@
@*             await Api.CancelAsync(State.CustomerRideId); *@
@*             State.UpdateCustomerRideStatus("Cancelled"); *@
@*             Log($"Ride cancelled", "warning"); *@
@*             await Task.Delay(1500); *@
@*             State.ClearCustomerRide(); *@
@*             ClearMarkersLocal(); *@
@*         } *@
@*         catch (Exception ex) *@
@*         { *@
@*             Log($"Cancel failed: {ex.Message}", "error"); *@
@*         } *@
@*         finally { _busy = false; } *@
@*     } *@
@* *@
@*     private void ClearMarkers() *@
@*     { *@
@*         _clickCount = 0; *@
@*         _pickup = null; *@
@*         _destination = null; *@
@*         _ = JS.InvokeVoidAsync("leafletInterop.removeMarker", "pickup"); *@
@*         _ = JS.InvokeVoidAsync("leafletInterop.removeMarker", "destination"); *@
@*     } *@
@* *@
@*     private void ClearMarkersLocal() *@
@*     { *@
@*         _clickCount = 0; *@
@*         _pickup = null; *@
@*         _destination = null; *@
@*     } *@
@* *@
@*     private async Task HandleSignalR(string status, string eventName) *@
@*     { *@
@*         if (status != "Requested") *@
@*         { *@
@*             _rideTimer?.Dispose(); *@
@*             _rideTimer = null; *@
@*         } *@
@*         State.UpdateCustomerRideStatus(status); *@
@*         Log($"SignalR {eventName} → {status}", "success"); *@
@*         if (status == "Completed") *@
@*         { *@
@*             await Task.Delay(3000); *@
@*             State.ClearCustomerRide(); *@
@*             ClearMarkersLocal(); *@
@*             await JS.InvokeVoidAsync("leafletInterop.clearMarkers"); *@
@*             await InvokeAsync(StateHasChanged); *@
@*         } *@
@*         await InvokeAsync(StateHasChanged); *@
@*     } *@
@* *@
@*     private async void HandleRideDeclined(string _) *@
@*     { *@
@*         State.UpdateCustomerRideStatus("Declined"); *@
@*         Log("Driver declined your ride. Looking for another driver…", "warning"); *@
@*         await InvokeAsync(StateHasChanged); *@
@*         await Task.Delay(2000); *@
@*         State.UpdateCustomerRideStatus("Requested"); *@
@*         await InvokeAsync(StateHasChanged); *@
@*     } *@
@* *@
@*     private void StartCountdown() *@
@*     { *@
@*         _rideTimer?.Dispose(); *@
@*         _rideCreatedAt = DateTime.UtcNow; *@
@*         _timeRemaining = TimeSpan.FromMinutes(1); *@
@* *@
@*         _rideTimer = new Timer(async _ => *@
@*         { *@
@*             _timeRemaining = TimeSpan.FromMinutes(1) - (DateTime.UtcNow - _rideCreatedAt); *@
@* *@
@*             if (_timeRemaining <= TimeSpan.Zero) *@
@*             { *@
@*                 _rideTimer?.Dispose(); *@
@*                 _rideTimer = null; *@
@* *@
@*                 if (State.CustomerRideStatus == "Requested") *@
@*                 { *@
@*                     try *@
@*                     { *@
@*                         await Api.CancelAsync(State.CustomerRideId!); *@
@*                         State.UpdateCustomerRideStatus("Cancelled"); *@
@*                         Log("No driver found. Ride auto-cancelled.", "warning"); *@
@*                         await Task.Delay(2000); *@
@*                         await InvokeAsync(() => *@
@*                         { *@
@*                             State.ClearCustomerRide(); *@
@*                             ClearMarkersLocal(); *@
@*                             _ = JS.InvokeVoidAsync("leafletInterop.clearMarkers"); *@
@*                             StateHasChanged(); *@
@*                         }); *@
@*                     } *@
@*                     catch (Exception ex) *@
@*                     { *@
@*                         Log($"Auto-cancel failed: {ex.Message}", "error"); *@
@*                     } *@
@*                 } *@
@*                 return; *@
@*             } *@
@* *@
@*             await InvokeAsync(StateHasChanged); *@
@*         }, null, TimeSpan.Zero, TimeSpan.FromSeconds(1)); *@
@*     } *@
@* *@
@*     private void Log(string message, string level = "info") *@
@*         => OnLog.InvokeAsync(new LogEntry { Message = message, Level = level }); *@
@* *@
@*     public void Dispose() *@
@*     { *@
@*         _rideTimer?.Dispose(); *@
@*         MapComponent.MapClicked -= HandleMapClick; *@
@*         SignalR.OnRideDeclined -= HandleRideDeclined; *@
@*     } *@
@* } *@


@inject AppState State
@inject ApiService Api
@inject SignalRService SignalR
@inject ApiSettings ApiSettings
@inject IJSRuntime JS
@implements IDisposable
@using System.Threading

<div class="panel">
    <div class="panel-title">Customer — Auth</div>
    <div class="input-row">
        <input type="tel" placeholder="+995 5XX XXX XXX" @bind="_phone" disabled="@State.IsCustomerLoggedIn" />
    </div>
    <div class="input-row">
        <input type="password" placeholder="Password" @bind="_pin" disabled="@State.IsCustomerLoggedIn" />
    </div>
    <div class="btn-row">
        <button class="btn btn-accent" @onclick="Login" disabled="@(State.IsCustomerLoggedIn || _busy)">Login</button>
        <button class="btn btn-customer" @onclick="Register" disabled="@(State.IsCustomerLoggedIn || _busy)">Register</button>
        @if (State.IsCustomerLoggedIn)
        {
            <button class="btn btn-danger btn-sm" @onclick="Logout">Logout</button>
        }
    </div>
    @if (State.IsCustomerLoggedIn)
    {
        <div class="coord-display" style="margin-top:6px;">Logged in as @State.CustomerPhone</div>
    }
    @if (!string.IsNullOrEmpty(_authError))
    {
        <div style="color:var(--danger);font-size:11px;margin-top:4px;">@_authError</div>
    }
</div>

@if (State.IsCustomerLoggedIn && string.IsNullOrEmpty(State.CustomerRideId))
{
    <div class="panel">
        <div class="panel-title">Create Ride</div>
        <p class="hint">Click map: 1st click = pickup 📍, 2nd click = destination 🏁</p>

        @if (_pickup.HasValue)
        {
            <div class="coord-display">📍 Pickup: @_pickup.Value.lat.ToString("F5"), @_pickup.Value.lng.ToString("F5")</div>
        }
        else
        {
            <div class="coord-display" style="color:var(--text-dim);">📍 Pickup: waiting for map click…</div>
        }

        @if (_destination.HasValue)
        {
            <div class="coord-display" style="margin-top:4px;">🏁 Dest: @_destination.Value.lat.ToString("F5"), @_destination.Value.lng.ToString("F5")</div>
        }
        else
        {
            <div class="coord-display" style="margin-top:4px;color:var(--text-dim);">🏁 Dest: waiting for map click…</div>
        }

        <div class="btn-row" style="margin-top:8px;">
            <button class="btn btn-customer" @onclick="CreateRide"
                    disabled="@(!_pickup.HasValue || !_destination.HasValue || _busy)">
                Create Ride
            </button>
            <button class="btn btn-danger btn-sm" @onclick="ClearMarkers">Clear</button>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(State.CustomerRideId))
{
    <div class="panel">
        <div class="panel-title">Active Ride</div>
        <div class="info-row">
            <span class="info-label">Ride ID</span>
            <span class="info-value">@State.CustomerRideId[..Math.Min(8, State.CustomerRideId.Length)]…</span>
        </div>
        <div class="info-row">
            <span class="info-label">Status</span>
            <span class="status-badge status-@State.CustomerRideStatus?.ToLower()">@State.CustomerRideStatus</span>
        </div>

        @if (State.CustomerRideStatus == "Requested" && _rideTimer != null)
        {
            <div class="countdown-container">
                <div class="countdown-label">Driver search expires in</div>
                <div class="countdown @(IsUrgent ? "countdown-urgent" : "")">
                    ⏱ @CountdownText
                </div>
                @if (IsUrgent)
                {
                    <div class="countdown-warning">Hurry! Ride will be cancelled soon</div>
                }
            </div>
        }

        <div style="margin-top:8px;">
            <button class="btn btn-danger btn-sm" @onclick="CancelRide"
                    disabled="@(IsRideClosed || _busy)">
                Cancel Ride
            </button>
        </div>

        @if (!IsRideClosed)
        {
            <div class="chat-panel">
                <div class="info-label" style="margin-bottom:6px;">Chat with driver</div>
                <div class="chat-thread" id="@_chatContainerId">
                    @if (_chatMessages.Count == 0)
                    {
                        <div class="chat-empty">No messages yet.</div>
                    }
                    else
                    {
                        @foreach (var chat in _chatMessages)
                        {
                            <div class="chat-row @(chat.IsOutgoing ? "outgoing" : "incoming")">
                                <article class="chat-bubble">
                                    <div class="chat-meta">
                                        <span class="chat-author">@chat.Author</span>
                                        <span>@chat.SentAt.ToLocalTime().ToString("HH:mm:ss")</span>
                                        @if (chat.IsEdited)
                                        {
                                            <span class="chat-edited">edited</span>
                                        }
                                    </div>
                                    <div class="chat-message">@chat.Message</div>
                                </article>
                            </div>
                        }
                    }
                </div>
                @* TESTING: manual driver ID input so we can chat before a real driver accepts. *@
                @if (string.IsNullOrWhiteSpace(_activeDriverId))
                {
                    <div class="input-row" style="margin-bottom:6px;">
                        <input type="text"
                               placeholder="Target Driver ID (Guid) — testing"
                               @bind="_testDriverId"
                               @bind:event="oninput"
                               disabled="@_busy" />
                    </div>
                }
                <div class="input-row">
                    <input type="text"
                           placeholder="@(_isEditingLastMessage ? "Edit your last message" : "Write a note for the driver")"
                           @bind="_chatDraft"
                           @bind:event="oninput"
                           @onkeydown="HandleChatKeyDown"
                           maxlength="200"
                           disabled="@_busy" />
                    <button class="btn btn-customer btn-sm"
                            @onclick="SendMessageToDriver"
                            disabled="@(_busy || string.IsNullOrWhiteSpace(_chatDraft) || string.IsNullOrWhiteSpace(TargetDriverId))">
                        @(_isEditingLastMessage ? "Save" : "Send")
                    </button>
                </div>
                <div class="chat-actions">
                    <button class="btn btn-customer btn-sm"
                            @onclick="BeginEditLastMessage"
                            disabled="@(_busy || !CanEditLastOwnMessage)">
                        Edit Last
                    </button>
                    @if (_isEditingLastMessage)
                    {
                        <button class="btn btn-danger btn-sm" @onclick="CancelEditMessage" disabled="@_busy">
                            Cancel
                        </button>
                    }
                </div>
                @if (!string.IsNullOrWhiteSpace(_messageStatus))
                {
                    <div style="font-size:11px;margin-top:4px;color:@MessageStatusColor;">
                        @_messageStatus
                    </div>
                }
                @if (string.IsNullOrWhiteSpace(_activeDriverId))
                {
                    <div style="font-size:11px;margin-top:4px;color:var(--warning);">
                        @* TESTING: in the temporary debug flow we accept a manual driver ID
                           so the chat can be exercised before acceptance. *@
                        Testing mode: paste a Driver ID above to route messages, or wait for a driver to accept.
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter] public EventCallback<LogEntry> OnLog { get; set; }

    private string _phone = "";
    private string _pin = "";
    private string _authError = "";
    private bool _busy;
    private (double lat, double lng)? _pickup;
    private (double lat, double lng)? _destination;
    private int _clickCount;
    private string _chatDraft = "";
    private string _messageStatus = "";
    private string? _activeDriverId;
    private string _testDriverId = ""; // TESTING: manual target so chat works during Requested.
    private string? _editingMessageId;
    private bool _isEditingLastMessage;
    private bool _scrollChatToBottom;
    private readonly List<ChatLine> _chatMessages = new();
    private const string _chatContainerId = "customer-chat-thread";

    private Timer? _rideTimer;
    private DateTime _rideCreatedAt;
    private TimeSpan _timeRemaining = TimeSpan.FromMinutes(1);

    private string CountdownText => _timeRemaining <= TimeSpan.Zero ? "00:00" : $"00:{_timeRemaining.Seconds:D2}";
    private bool IsUrgent => _timeRemaining < TimeSpan.FromSeconds(15);
    private bool IsRideClosed => State.CustomerRideStatus is "Completed" or "Cancelled";
    private string MessageStatusColor => _messageStatus.StartsWith("Sent", StringComparison.OrdinalIgnoreCase)
        ? "var(--accent)"
        : _messageStatus.StartsWith("Editing", StringComparison.OrdinalIgnoreCase)
            ? "var(--warning)"
            : "var(--danger)";
    private ChatLine? LastOwnMessage => _chatMessages.LastOrDefault(m => m.IsOutgoing);
    private bool CanEditLastOwnMessage => LastOwnMessage is not null;

    // TESTING: route via real assigned driver if available, else fall back to the manual testing input.
    private string TargetDriverId =>
        !string.IsNullOrWhiteSpace(_activeDriverId)
            ? _activeDriverId!
            : (_testDriverId ?? "").Trim();

    protected override void OnInitialized()
    {
        MapComponent.MapClicked += HandleMapClick;
        
        SignalR.OnDriverFound += HandleDriverFound;
        SignalR.OnDriverArrived += HandleDriverArrived;
        SignalR.OnRideStarted += HandleRideStarted;
        SignalR.OnRideCompleted += HandleDriverCompleted;
        SignalR.OnRideCancelled += HandleRideCancelled;
        SignalR.OnReceiveNotification += HandleNotification;

        SignalR.OnForceLogout += HandleForceLogout;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_scrollChatToBottom)
        {
            _scrollChatToBottom = false;
            await JS.InvokeVoidAsync("appInterop.scrollToBottomById", _chatContainerId);
        }
    }

    private async void HandleDriverFound(string _) => await HandleSignalR("Accepted", "DriverFound");
    private async void HandleDriverArrived(string _) => await HandleSignalR("Arrived", "DriverArrived");
    private async void HandleRideStarted(string _) => await HandleSignalR("OnTheWay", "RideStarted");
    private async void HandleDriverCompleted(string _) => await HandleSignalR("Completed", "RideCompleted");

    private void HandleNotification(string raw)
    {
        if (ChatNotification.TryParse(raw, out var chat) && chat is not null)
        {
            if (!string.IsNullOrEmpty(State.CustomerRideId) &&
                string.Equals(chat.RideId, State.CustomerRideId, StringComparison.OrdinalIgnoreCase))
            {
                UpsertChatMessage(chat);
                _messageStatus = "";
                _ = InvokeAsync(StateHasChanged);
                return;
            }
        }

        Log($"Notification: {raw}", "info");
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleRideCancelled(string json)
    {
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            if (doc.RootElement.TryGetProperty("rideId", out var idProp) ||
                doc.RootElement.TryGetProperty("RideId", out idProp))
            {
                var id = idProp.GetString();
                if (!string.IsNullOrEmpty(State.CustomerRideId) && State.CustomerRideId == id)
                {
                    _rideTimer?.Dispose();
                    _rideTimer = null;
                    State.ClearCustomerRide();
                    ClearMarkersLocal();
                    ClearMessageState();
                    Log("Ride was cancelled", "warning");
                }
            }
        }
        catch { }
        InvokeAsync(StateHasChanged);
    }

    private async void HandleForceLogout(object data)
    {
        await InvokeAsync(async () => 
        {
            Log("Force Logout: Session invalidated by another login", "error");
            
            _authError = "თქვენ შეხვედით სხვა მოწყობილობიდან. სესია გაუქმებულია.";
            
            // ლოკალური წმენდა (სერვერზე Cancel-ის გარეშე)
            _rideTimer?.Dispose();
            _rideTimer = null;
            
            await SignalR.DisconnectAsync();
            Api.ClearToken();
            State.SetCustomerAuth("", "", "");
            State.ClearCustomerRide();
            
            _phone = "";
            _pin = "";
            ClearMarkersLocal();
            ClearMessageState();
            await JS.InvokeVoidAsync("leafletInterop.clearMarkers");
            
            StateHasChanged();
        });
    }

    private void HandleMapClick(double lat, double lng)
    {
        if (!State.IsCustomerLoggedIn || !string.IsNullOrEmpty(State.CustomerRideId)) return;

        _clickCount++;
        if (_clickCount % 2 == 1)
        {
            _pickup = (lat, lng);
            _ = JS.InvokeVoidAsync("leafletInterop.removeMarker", "pickup");
            _ = JS.InvokeVoidAsync("leafletInterop.addMarker", "pickup", lat, lng, "📍", $"Pickup: {lat:F4}, {lng:F4}");
        }
        else
        {
            _destination = (lat, lng);
            _ = JS.InvokeVoidAsync("leafletInterop.removeMarker", "destination");
            _ = JS.InvokeVoidAsync("leafletInterop.addMarker", "destination", lat, lng, "🏁", $"Destination: {lat:F4}, {lng:F4}");
        }
        InvokeAsync(StateHasChanged);
    }

    private async Task Register()
    {
        _authError = "";
        _busy = true;
        try
        {
            var (token, userId) = await Api.RegisterAsync(_phone, "Customer", _pin);
            Api.SetToken(token);
            State.SetCustomerAuth(token, userId, _phone);
            await ConnectHub();
            await RecoverActiveRide();
            Log($"Registered customer {_phone}", "success");
        }
        catch (Exception ex)
        {
            _authError = ex.Message;
            Log($"Register failed: {ex.Message}", "error");
        }
        finally { _busy = false; }
    }

    private async Task Login()
    {
        _authError = "";
        _busy = true;
        try
        {
            var result = await Api.LoginAsync(_phone, _pin);
            Api.SetToken(result.AccessToken);
            State.SetCustomerAuth(result.AccessToken, "", _phone);
            await ConnectHub();
            await RecoverActiveRide();
            Log($"Customer login OK: {_phone}", "success");
        }
        catch (Exception ex)
        {
            _authError = ex.Message;
            Log($"Login failed: {ex.Message}", "error");
        }
        finally { _busy = false; }
    }

    private async Task ConnectHub()
    {
        SignalR.Configure($"{ApiSettings.BaseUrl}/hubs/rides", () => State.CustomerToken ?? "");
        await SignalR.ConnectAsync();
        Log("SignalR connected", "success");
    }

    private async Task RecoverActiveRide()
    {
        try
        {
            var activeRide = await Api.GetActiveRideAsync();
            if (activeRide != null)
            {
                State.SetCustomerRide(activeRide.Id.ToString(), activeRide.StatusText);
                _activeDriverId = activeRide.DriverId?.ToString();
                Log($"Recovered active ride: {activeRide.Id.ToString()[..8]}…", "success");
                if (activeRide.StatusText == "Requested")
                    StartCountdown();
            }
        }
        catch { }
    }

    private async Task Logout()
    {
        // ხელით ლოგაუტისას ვაუქმებთ რეიდს (თუ Requested-ია)
        if (!string.IsNullOrEmpty(State.CustomerRideId) && State.CustomerRideStatus == "Requested")
        {
            try { await Api.CancelAsync(State.CustomerRideId); } catch { }
        }

        _rideTimer?.Dispose();
        _rideTimer = null;

        await SignalR.DisconnectAsync();
        Api.ClearToken();
        State.SetCustomerAuth("", "", "");
        State.ClearCustomerRide();
        _phone = "";
        _pin = "";
        ClearMarkersLocal();
        ClearMessageState();
        await JS.InvokeVoidAsync("leafletInterop.clearMarkers");
        Log("Logged out", "info");
    }

    private async Task CreateRide()
    {
        if (!_pickup.HasValue || !_destination.HasValue) return;
        _busy = true;
        try
        {
            var ride = await Api.CreateRideAsync(
                (decimal)_pickup.Value.lat, (decimal)_pickup.Value.lng,
                (decimal)_destination.Value.lat, (decimal)_destination.Value.lng);
            State.SetCustomerRide(ride.Id.ToString(), "Requested");
            Log($"Ride created! Price: {ride.Price:F2} GEL", "success");
            StartCountdown();
        }
        catch (Exception ex) { Log($"Create ride failed: {ex.Message}", "error"); }
        finally { _busy = false; }
    }

    private async Task CancelRide()
    {
        if (string.IsNullOrEmpty(State.CustomerRideId)) return;
        _rideTimer?.Dispose();
        _rideTimer = null;
        _busy = true;
        try
        {
            await Api.CancelAsync(State.CustomerRideId);
            State.UpdateCustomerRideStatus("Cancelled");
            ClearMessageState();
            Log($"Ride cancelled", "warning");
            await Task.Delay(1500);
            State.ClearCustomerRide();
            ClearMarkersLocal();
        }
        catch (Exception ex) { Log($"Cancel failed: {ex.Message}", "error"); }
        finally { _busy = false; }
    }

    private void ClearMarkers()
    {
        ClearMarkersLocal();
        _ = JS.InvokeVoidAsync("leafletInterop.clearMarkers");
    }

    private void ClearMarkersLocal()
    {
        _clickCount = 0;
        _pickup = null;
        _destination = null;
    }

    private void ClearMessageState()
    {
        _chatDraft = "";
        _messageStatus = "";
        _activeDriverId = null;
        _testDriverId = ""; // TESTING
        _editingMessageId = null;
        _isEditingLastMessage = false;
        _chatMessages.Clear();
        _scrollChatToBottom = false;
    }

    private async Task HandleSignalR(string status, string eventName)
    {
        if (status != "Requested")
        {
            _rideTimer?.Dispose();
            _rideTimer = null;
        }
        State.UpdateCustomerRideStatus(status);
        if (status is "Accepted" or "Arrived" or "OnTheWay")
            await RefreshAssignedDriverIdAsync();
        Log($"SignalR {eventName} → {status}", "success");
        if (status == "Completed")
        {
            ClearMessageState();
            await Task.Delay(3000);
            State.ClearCustomerRide();
            ClearMarkersLocal();
            await JS.InvokeVoidAsync("leafletInterop.clearMarkers");
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task SendMessageToDriver()
    {
        if (string.IsNullOrEmpty(State.CustomerRideId) || string.IsNullOrWhiteSpace(_chatDraft))
            return;

        // TESTING: TargetDriverId falls back to the manual testing input when no driver assigned.
        var targetId = TargetDriverId;
        if (string.IsNullOrWhiteSpace(targetId))
        {
            _messageStatus = "Driver is not available for chat yet.";
            return;
        }

        _busy = true;
        _messageStatus = "";

        var message = _chatDraft.Trim();
        var existing = _isEditingLastMessage && !string.IsNullOrWhiteSpace(_editingMessageId)
            ? _chatMessages.LastOrDefault(x => x.MessageId == _editingMessageId)
            : null;
        var messageId = existing?.MessageId ?? Guid.NewGuid().ToString("N");
        var sentAt = existing?.SentAt ?? DateTime.UtcNow;
        var payload = existing is null
            ? ChatNotification.CreateMessagePayload(State.CustomerRideId, messageId, "Customer", message, sentAt)
            : ChatNotification.CreateEditPayload(State.CustomerRideId, messageId, "Customer", message, sentAt);

        try
        {
            await SendChatPayloadToDriver(targetId, payload);
            UpsertChatMessage(new ChatNotification(
                existing is null ? ChatNotification.ChatType : ChatNotification.ChatEditType,
                State.CustomerRideId,
                messageId,
                "Customer",
                message,
                sentAt,
                existing is null ? null : DateTime.UtcNow));
            _chatDraft = "";
            _editingMessageId = null;
            _isEditingLastMessage = false;
            _messageStatus = existing is null ? "Sent to driver" : "Sent edit to driver";
            Log(existing is null ? $"Message sent to driver: {message}" : $"Message edited for driver: {message}", "success");
        }
        catch (Exception ex)
        {
            _messageStatus = $"Send failed: {ex.Message}";
            Log($"Send message failed: {ex.Message}", "error");
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task HandleChatKeyDown(KeyboardEventArgs e)
    {
        if (e.Key != "Enter" || e.ShiftKey)
            return;
        if (_busy || string.IsNullOrWhiteSpace(_chatDraft) || string.IsNullOrWhiteSpace(TargetDriverId))
            return;
        await SendMessageToDriver();
    }

    private void BeginEditLastMessage()
    {
        var lastOwn = LastOwnMessage;
        if (lastOwn is null)
            return;

        _chatDraft = lastOwn.Message;
        _editingMessageId = lastOwn.MessageId;
        _isEditingLastMessage = true;
        _messageStatus = "Editing your last message";
    }

    private void CancelEditMessage()
    {
        _chatDraft = "";
        _editingMessageId = null;
        _isEditingLastMessage = false;
        _messageStatus = "";
    }

    private void UpsertChatMessage(ChatNotification chat)
    {
        var existingIndex = _chatMessages.FindIndex(m => m.MessageId == chat.MessageId);
        var isOutgoing = string.Equals(chat.SenderRole, "Customer", StringComparison.OrdinalIgnoreCase);
        var line = new ChatLine(
            chat.MessageId,
            string.Equals(chat.SenderRole, "Customer", StringComparison.OrdinalIgnoreCase) ? "Customer" : "Driver",
            chat.Message,
            isOutgoing,
            chat.SentAt,
            chat.IsEdit || chat.EditedAt.HasValue);

        if (existingIndex >= 0)
            _chatMessages[existingIndex] = line;
        else
            _chatMessages.Add(line);

        _scrollChatToBottom = true;
    }

    private async Task SendChatPayloadToDriver(string driverId, string payload)
    {
        if (!Guid.TryParse(driverId, out var parsedDriverId))
            throw new Exception("Assigned driver ID is invalid.");

        foreach (var method in new[] { "SendMessageToDriver", "send-message-to-driver" })
        {
            try
            {
                await SignalR.SendAsync(method, parsedDriverId, payload);
                return;
            }
            catch
            {
            }
        }

        throw new Exception("No compatible driver message hub method was available.");
    }

    private async Task RefreshAssignedDriverIdAsync()
    {
        if (string.IsNullOrEmpty(State.CustomerRideId))
            return;

        try
        {
            var ride = await Api.GetRideAsync(State.CustomerRideId);
            _activeDriverId = ride.DriverId?.ToString();
        }
        catch
        {
        }
    }

    private void StartCountdown()
    {
        _rideTimer?.Dispose();
        _rideCreatedAt = DateTime.UtcNow;
        _timeRemaining = TimeSpan.FromMinutes(1);

        _rideTimer = new Timer(async _ =>
        {
            _timeRemaining = TimeSpan.FromMinutes(1) - (DateTime.UtcNow - _rideCreatedAt);

            if (_timeRemaining <= TimeSpan.Zero)
            {
                _rideTimer?.Dispose();
                _rideTimer = null;

                if (State.CustomerRideStatus == "Requested")
                {
                    try
                    {
                        await Api.CancelAsync(State.CustomerRideId!);
                        State.UpdateCustomerRideStatus("Cancelled");
                        Log("No driver found. Auto-cancelled.", "warning");
                        await Task.Delay(2000);
                        await InvokeAsync(() =>
                        {
                            State.ClearCustomerRide();
                            ClearMarkersLocal();
                            _ = JS.InvokeVoidAsync("leafletInterop.clearMarkers");
                            StateHasChanged();
                        });
                    }
                    catch { }
                }
                return;
            }
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }

    private void Log(string message, string level = "info")
        => OnLog.InvokeAsync(new LogEntry { Message = message, Level = level });

    public void Dispose()
    {
        _rideTimer?.Dispose();
        MapComponent.MapClicked -= HandleMapClick;
        SignalR.OnDriverFound -= HandleDriverFound;
        SignalR.OnDriverArrived -= HandleDriverArrived;
        SignalR.OnRideStarted -= HandleRideStarted;
        SignalR.OnRideCompleted -= HandleDriverCompleted;
        SignalR.OnRideCancelled -= HandleRideCancelled;
        SignalR.OnReceiveNotification -= HandleNotification;
        SignalR.OnForceLogout -= HandleForceLogout;
    }

    private record ChatLine(string MessageId, string Author, string Message, bool IsOutgoing, DateTime SentAt, bool IsEdited);
}
